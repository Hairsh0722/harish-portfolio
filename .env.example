# -------------------------------------------------------------------
# EmailJS credentials for the Contact form.
# 1. Create a free account at https://www.emailjs.com/
# 2. Add an Email Service (connect the Gmail you want to receive at:
#    harishhari98840@gmail.com) -> copy the Service ID.
# 3. Create an Email Template that uses these variables:
#      {{from_name}}   -> sender's name
#      {{reply_to}}    -> sender's email (set this as the template "Reply-To")
#      {{message}}     -> the message body
#    -> copy the Template ID.
# 4. In Account -> General, copy your Public Key.
# 5. Copy this file to `.env.local` and paste the three values below.
# 6. Restart `npm start` (CRA only reads env vars at startup).
#
# .env.local is gitignored, so your keys stay out of version control.
# For the deployed site, set these same vars in your host / CI environment.
# -------------------------------------------------------------------

REACT_APP_EMAILJS_SERVICE_ID=your_service_id_here
REACT_APP_EMAILJS_TEMPLATE_ID=your_template_id_here
REACT_APP_EMAILJS_PUBLIC_KEY=your_public_key_here
